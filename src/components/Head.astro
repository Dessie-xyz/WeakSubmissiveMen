---
import '../style/main.css';

interface Props {
    title: string;
}
const { title } = Astro.props;
---
<head>
	<meta charset="utf-8" />

	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

	<meta name="viewport" content="width=device-width" />

	<title>DessieOwO | {title}</title>

	<meta name="title" content="DessieOwO | {title}"  />
	<meta name="description" content="The silliest little furry calculator! UwU" />

	<meta property="og:type" content="website" />
	<meta property="og:url" content={Astro.url} />
	<meta property="og:title" content="DessieOwO | {title}" />
	<meta property="og:description" content="The silliest little furry calculator! UwU" />
	<meta property="og:image" content="/favicon.svg"/>

	<!-- Twitter -->
	<meta property="twitter:card" content="summary_large_image" />
	<meta property="twitter:url" content={Astro.url} />
	<meta property="twitter:title" content="DessieOwO | {title}" />
	<meta property="twitter:description" content="The silliest little furry calculator! UwU" />
	<meta property="twitter:image" content="/favicon.svg" />
</head>