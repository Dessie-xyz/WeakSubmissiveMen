---
import Basic from "../layouts/Basic.astro";
import { getCollection } from 'astro:content';
import { Image } from "astro:assets";
import titleLogo from "../images/Title.png";

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0,1);
---
<style>
.post-card {
  display: block;
  padding: 1rem;
  margin-bottom: 1rem;
  background-color: var(--secondary-bg-color);
  color: var(--secondary-text-color);
  border-radius: 8px;
  text-decoration: none;
}
.post-card:hover {
  background-color: var(--secondary-text-color);
  color: var(--secondary-bg-color);
}

</style>

<Basic title="Home">
	<Image src={titleLogo} alt="Weak Submissive Men" style="width:834px;height:245px;margin-left: auto;margin-right: auto;align:center;display:block;" />
	<p>This website is in development. Anything you see here may change in the future. Please use the <a href="/contact">contact info on our about page</a> to give your feedback.</p>
	<hr>
	<h1>Latest Blog Post</h1>
	{posts.map((post) => (
    	<a href={`/blog/${post.id}`} class="post-card">
    		<h2 >{post.data.title}</h2><p>({post.data.pubDate.toLocaleDateString()})</p>
    		{post.data.description && <p>&gt;&gt; {post.data.description}</p>}
    	</a>
  	))}
</Basic>
