---
import Basic from "../../layouts/Basic.astro";
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Basic title="Blog">
    <h1 class="mainHeader">Blog</h1>
    <p>Nothing here yet, but stay tuned!</p>
      {posts.map((post) => (
    <a href={`/blog/${post.id}`} style="
        display: block;
        padding: 1rem;
        margin-bottom: 1rem;
        background-color: var(--secondary-bg-color);
        color: var(--secondary-text-color);
        border-radius: 8px;
        text-decoration: none;
    ">
      <h3 >{post.data.title}</h3><p>({post.data.pubDate.toLocaleDateString()})</p>
      {post.data.description && <p>&gt;&gt; {post.data.description}</p>}
    </a>
  ))}
  
</Basic>