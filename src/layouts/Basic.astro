---
interface Props {
    title: string;
	description?: string;
}
import Footer from '../components/Footer.astro';
import Head from '../components/Head.astro';
import Navbar from '../components/Navbar.astro';
const { title, description } = Astro.props;
---

<html lang="en">
	<Head title = {title} description = {description}/>
	<body>
		<div class="notFooter">
		<Navbar />
		<main>
			<slot />
		</main>
		</div>
		<Footer />
	</body>
</html>